{
  "daemon": true,
  "run": [
    {
      "when": "{{platform !== 'win32'}}",
      "method": "shell.run",
      "params": {
        "message": "ollama serve > /dev/null 2>&1 &"
      }
    },
    {
      "when": "{{platform === 'win32'}}",
      "method": "shell.run",
      "params": {
        "message": "start /B ollama serve"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "venv": "venv",
        "message": "python server/app.py --port {{port}}",
        "on": [{
          "event": "/(http:\\/\\/[0-9.:]+)/",
          "done": true
        }],
        "env": {
          "DATA_DIR": "{{cwd}}{{platform === 'win32' ? '\\\\data' : '/data'}}",
          "OLLAMA_URL": "http://127.0.0.1:11434",
          "PYTHONIOENCODING": "utf-8",
          "PYTHONUTF8": "1"
        }
      }
    },
    {
      "method": "local.set",
      "params": {
        "url": "{{input.event[0]}}"
      }
    },
    {
      "method": "log",
      "params": {
        "html": "<p>&#x2705; CCS Cashflow Assistant iniciado en <strong>{{local.url}}</strong></p>"
      }
    }
  ]
}
