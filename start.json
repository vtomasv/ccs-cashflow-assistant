{
  "daemon": true,
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<div style='font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:20px 20px 0'><div style='display:flex;align-items:center;gap:12px;margin-bottom:12px'><div style='width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#0D3DA6,#0956B8);display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;flex-shrink:0'>$</div><div><h3 style='margin:0;font-size:16px;color:#e2e8f0'>Iniciando CCS Cashflow Assistant</h3><p style='margin:2px 0 0;color:#94a3b8;font-size:12px'>Preparando servicios de flujo de caja...</p></div></div></div>"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:8px 20px'><div style='display:flex;align-items:center;gap:8px;padding:8px 14px;background:#0f172a;border:1px solid #1e293b;border-radius:6px'><div style='width:8px;height:8px;border-radius:50%;background:#06b6d4;flex-shrink:0'></div><span style='color:#94a3b8;font-size:12px'>Verificando dependencias Python...</span></div></div>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "venv": "venv",
        "message": "python scripts/verify_deps.py"
      }
    },
    {
      "method": "log",
      "params": {
        "html": "<div style='font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:4px 20px'><div style='display:flex;align-items:center;gap:8px;padding:8px 14px;background:#0f2d1a;border:1px solid #16a34a33;border-radius:6px'><span style='color:#22c55e;font-size:14px'>&#10003;</span><span style='color:#86efac;font-size:12px'>Dependencias verificadas</span></div></div>"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:8px 20px'><div style='display:flex;align-items:center;gap:8px;padding:8px 14px;background:#0f172a;border:1px solid #1e293b;border-radius:6px'><div style='width:8px;height:8px;border-radius:50%;background:#f59e0b;flex-shrink:0'></div><span style='color:#94a3b8;font-size:12px'>Verificando motor de IA (Ollama)...</span></div></div>"
      }
    },
    {
      "when": "{{platform !== 'win32'}}",
      "method": "shell.run",
      "params": {
        "message": "curl -s http://127.0.0.1:11434/api/tags > /dev/null 2>&1 && echo OLLAMA_ALREADY_RUNNING || (ollama serve > /dev/null 2>&1 & sleep 3 && echo OLLAMA_STARTED)"
      }
    },
    {
      "when": "{{platform === 'win32'}}",
      "method": "shell.run",
      "params": {
        "message": "curl -s http://127.0.0.1:11434/api/tags > nul 2>&1 && echo OLLAMA_ALREADY_RUNNING || (start /B ollama serve && ping -n 4 127.0.0.1 > nul && echo OLLAMA_STARTED)"
      }
    },
    {
      "method": "log",
      "params": {
        "html": "<div style='font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:4px 20px'><div style='display:flex;align-items:center;gap:8px;padding:8px 14px;background:#0f2d1a;border:1px solid #16a34a33;border-radius:6px'><span style='color:#22c55e;font-size:14px'>&#10003;</span><span style='color:#86efac;font-size:12px'>Ollama listo</span></div></div>"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:8px 20px'><div style='display:flex;align-items:center;gap:8px;padding:8px 14px;background:#0f172a;border:1px solid #1e293b;border-radius:6px'><div style='width:8px;height:8px;border-radius:50%;background:#3b82f6;flex-shrink:0'></div><span style='color:#94a3b8;font-size:12px'>Iniciando servidor de aplicaci&oacute;n...</span></div></div>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "venv": "venv",
        "message": "python server/app.py --port {{port}}",
        "on": [{
          "event": "/(http:\\/\\/[0-9.:]+)/",
          "done": true
        }],
        "env": {
          "OLLAMA_URL": "http://127.0.0.1:11434",
          "PYTHONIOENCODING": "utf-8",
          "PYTHONUTF8": "1"
        }
      }
    },

    {
      "method": "local.set",
      "params": {
        "url": "{{input.event[0]}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:12px 20px'><div style='background:linear-gradient(135deg,#0f2d1a,#052e16);border:1px solid #16a34a44;border-radius:10px;padding:16px;text-align:center'><div style='display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:8px'><span style='color:#22c55e;font-size:16px'>&#10003;</span><span style='color:#22c55e;font-size:15px;font-weight:600'>Aplicaci&oacute;n lista</span></div><p style='color:#94a3b8;font-size:12px;margin:0'>Abriendo interfaz de usuario...</p></div></div>"
      }
    },
    {
      "method": "browser.open",
      "params": {
        "uri": "{{local.url}}"
      }
    }
  ]
}
